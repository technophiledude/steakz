generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATIONAL
  MANAGEMENT
  SENIOR
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StockRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum AlertType {
  LOW_STOCK
  HIGH_SALES
  LOW_SALES
  COMPLIANCE_DUE
  STAFF_SHORTAGE
  SYSTEM
}

enum AlertStatus {
  UNREAD
  READ
  RESOLVED
}

enum ComplianceType {
  FOOD_SAFETY
  ALLERGEN
  TEMPERATURE_LOG
  HYGIENE_AUDIT
}

model User {
  id         Int         @id @default(autoincrement())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(OPERATIONAL)
  isActive   Boolean     @default(true)
  branch     Branch?     @relation(fields: [branchId], references: [id])
  branchId   Int?
  timesheets Timesheet[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Branch {
  id                Int                @id @default(autoincrement())
  name              String
  location          String
  city              String
  phone             String?
  isActive          Boolean            @default(true)
  users             User[]
  orders            Order[]
  stockItems        StockItem[]
  timesheets        Timesheet[]
  tasks             Task[]
  complianceRecords ComplianceRecord[]
  alerts            Alert[]
  dailySales        DailySale[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model MenuItem {
  id         Int         @id @default(autoincrement())
  name       String
  category   String
  price      Float
  isActive   Boolean     @default(true)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Order {
  id          Int         @id @default(autoincrement())
  branch      Branch      @relation(fields: [branchId], references: [id])
  branchId    Int
  tableNumber Int?
  status      OrderStatus @default(PENDING)
  total       Float       @default(0)
  items       OrderItem[]
  createdById Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId Int
  quantity   Int
  unitPrice  Float
  createdAt  DateTime @default(now())
}

model StockItem {
  id               Int             @id @default(autoincrement())
  name             String
  category         String
  unit             String
  currentQuantity  Float           @default(0)
  reorderThreshold Float           @default(10)
  branch           Branch          @relation(fields: [branchId], references: [id])
  branchId         Int
  requests         StockRequest[]
  movements        StockMovement[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model StockRequest {
  id            Int                @id @default(autoincrement())
  stockItem     StockItem          @relation(fields: [stockItemId], references: [id])
  stockItemId   Int
  quantity      Float
  notes         String?
  status        StockRequestStatus @default(PENDING)
  requestedById Int
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model StockMovement {
  id          Int       @id @default(autoincrement())
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  stockItemId Int
  type        String
  quantity    Float
  notes       String?
  createdById Int
  createdAt   DateTime  @default(now())
}

model Timesheet {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    Int
  date        DateTime
  hoursWorked Float
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id            Int       @id @default(autoincrement())
  branch        Branch    @relation(fields: [branchId], references: [id])
  branchId      Int
  title         String
  description   String?
  isCompleted   Boolean   @default(false)
  completedById Int?
  completedAt   DateTime?
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Alert {
  id        Int         @id @default(autoincrement())
  type      AlertType
  title     String
  message   String
  branch    Branch?     @relation(fields: [branchId], references: [id])
  branchId  Int?
  status    AlertStatus @default(UNREAD)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model ComplianceRecord {
  id           Int            @id @default(autoincrement())
  branch       Branch         @relation(fields: [branchId], references: [id])
  branchId     Int
  type         ComplianceType
  description  String
  result       String?
  recordedById Int
  recordedAt   DateTime
  createdAt    DateTime       @default(now())
}

model DailySale {
  id           Int      @id @default(autoincrement())
  branch       Branch   @relation(fields: [branchId], references: [id])
  branchId     Int
  date         DateTime
  totalRevenue Float
  orderCount   Int
  avgSpend     Float
  covers       Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([branchId, date])
}
